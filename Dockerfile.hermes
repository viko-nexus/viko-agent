# ─── Stage 1: uv binary ───────────────────────────────────────────────────────
# Image published as ghcr.io/viko-nexus/viko-agent
FROM ghcr.io/astral-sh/uv:0.11.6-python3.13-trixie AS uv_source

# ─── Stage 2: Node 22 LTS ─────────────────────────────────────────────────────
FROM node:22-bookworm-slim AS node_source

# ─── Stage 3: Clone Hermes source ─────────────────────────────────────────────
FROM debian:bookworm-slim AS hermes_source
# Pin hermes to a tested commit. To upgrade: update this SHA, rebuild, re-verify patches.
# 2026-07-10: bumped to tagged release v2026.7.7.2 (was untagged commit f1345290, ~1560 commits behind).
ARG HERMES_COMMIT=9de9c25f620ff7f1ce0fd5457d596052d5159596
RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates && rm -rf /var/lib/apt/lists/*
RUN git clone https://github.com/NousResearch/hermes-agent.git /opt/hermes \
    && git -C /opt/hermes checkout "$HERMES_COMMIT"

# ─── Stage 4: Runtime ─────────────────────────────────────────────────────────
FROM debian:13.4

ENV PYTHONUNBUFFERED=1
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/hermes/.playwright
ENV npm_config_install_links=false

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    ca-certificates curl iputils-ping python3 python-is-python3 ripgrep ffmpeg \
    gcc g++ make cmake python3-dev python3-venv libffi-dev libolm-dev \
    procps git openssh-client docker-cli xz-utils && \
    rm -rf /var/lib/apt/lists/*

# ── s6-overlay: process supervision (same as official Hermes Dockerfile) ──────
ARG TARGETARCH
ARG S6_OVERLAY_VERSION=3.2.3.0
RUN set -eu; \
    case "${TARGETARCH:-amd64}" in \
        amd64) arch=x86_64 ;; \
        arm64) arch=aarch64 ;; \
        *) echo "Unsupported TARGETARCH: ${TARGETARCH}" >&2; exit 1 ;; \
    esac; \
    curl -fsSL --retry 3 -o /tmp/s6-noarch.tar.xz \
        "https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-noarch.tar.xz"; \
    curl -fsSL --retry 3 -o /tmp/s6-arch.tar.xz \
        "https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-${arch}.tar.xz"; \
    curl -fsSL --retry 3 -o /tmp/s6-symlinks.tar.xz \
        "https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-symlinks-noarch.tar.xz"; \
    tar -C / -Jxpf /tmp/s6-noarch.tar.xz; \
    tar -C / -Jxpf /tmp/s6-arch.tar.xz; \
    tar -C / -Jxpf /tmp/s6-symlinks.tar.xz; \
    rm /tmp/s6-*.tar.xz; \
    ln -sf /init /usr/bin/tini

# Build with host UID/GID so stage2-hook.sh skips the slow chown at startup.
# Pass --build-arg HERMES_UID=$(id -u) or rely on docker-compose args.
# IMPORTANT: this build UID owns the baked bridge node_modules + venv, so the
# RUNTIME HERMES_UID (.env) must match it — a mismatch makes the WhatsApp bridge
# unable to write its deps and it fails to start. CI passes the VPS deploy user's
# UID via deploy.yml build-args (1001 on the current VPS).
ARG HERMES_UID=501
ARG HERMES_GID=20
RUN groupadd -o -g ${HERMES_GID} hermes-grp 2>/dev/null || true && \
    useradd -u ${HERMES_UID} -o -m -d /opt/data hermes

# ── uv + Node 22 from source stages ───────────────────────────────────────────
COPY --chmod=0755 --from=uv_source /usr/local/bin/uv /usr/local/bin/uvx /usr/local/bin/
COPY --chmod=0755 --from=node_source /usr/local/bin/node /usr/local/bin/
COPY --from=node_source /usr/local/lib/node_modules/npm /usr/local/lib/node_modules/npm
COPY --from=node_source /usr/local/lib/node_modules/corepack /usr/local/lib/node_modules/corepack
RUN ln -sf /usr/local/lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm && \
    ln -sf /usr/local/lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx && \
    ln -sf /usr/local/lib/node_modules/corepack/dist/corepack.js /usr/local/bin/corepack

# ── Hermes source ─────────────────────────────────────────────────────────────
COPY --from=hermes_source /opt/hermes /opt/hermes

WORKDIR /opt/hermes

# ── npm: install deps + build frontend ────────────────────────────────────────
# Cached unless package.json / package-lock.json changes
RUN npm install --prefer-offline --no-audit && npm cache clean --force
RUN cd web && npm run build && cd ../ui-tui && npm run build
# Pre-install WhatsApp bridge deps so bridge starts instantly (avoids 30s race at container start)
RUN if [ -f /opt/hermes/scripts/whatsapp-bridge/package.json ]; then \
        cd /opt/hermes/scripts/whatsapp-bridge && npm install --prefer-offline --no-audit && npm cache clean --force; \
    fi

# ── Python: install deps via uv ───────────────────────────────────────────────
# Cached unless pyproject.toml / uv.lock changes
RUN uv sync --frozen --no-install-project \
    --extra all --extra messaging \
    --extra anthropic --extra bedrock --extra azure-identity \
    --extra hindsight --extra matrix

# ── Install Hermes as editable package ────────────────────────────────────────
RUN uv pip install --no-cache-dir --no-deps -e "."

# ── Extra tools: charts, web search, doc extraction (PDF/docx/pptx/xlsx), DB ──
# PDF + office-doc libs so the agent reads ANY attachment via the venv python, plus
# DB drivers so it can query ANY project database over an SSH tunnel: psycopg2
# (Postgres), PyMySQL (MySQL/MariaDB), pymongo (Mongo), redis, and SQLAlchemy as a
# universal URL-driven layer for SQL DBs. No per-media/per-DB code, no on-the-fly
# install. pymupdf is NOT a pinned Hermes dep (uv sync --no-install-project + -e .
# --no-deps skip it), so install it here.
RUN uv pip install --no-cache-dir matplotlib duckduckgo-search pymupdf python-docx python-pptx openpyxl psycopg2-binary PyMySQL pymongo redis SQLAlchemy
# Same libs in the SYSTEM python3 too. The agent's terminal runs in a LOGIN shell
# where /etc/profile resets PATH so `python3` = /usr/bin/python3 (not the venv),
# so these must be importable there as well or attachment reads / DB queries fail.
RUN uv pip install --python /usr/bin/python3 --break-system-packages --no-cache-dir pymupdf python-docx python-pptx openpyxl psycopg2-binary PyMySQL pymongo redis SQLAlchemy

# ── Chromium (browser tools) + DB CLIs (psql/mysql/redis over an SSH tunnel) ──
RUN apt-get update && \
    apt-get install -y --no-install-recommends chromium postgresql-client default-mysql-client redis-tools && \
    rm -rf /var/lib/apt/lists/*
ENV CHROME_PATH=/usr/bin/chromium

# ── Document conversion: pandoc (markdown-aware) + LibreOffice headless ───────
# pandoc renders markdown (**bold**, # headings, bullets, tables) into a REAL .docx;
# LibreOffice then converts any office doc to PDF. Clean-output workflow:
#   pandoc in.md -o out.docx   →   soffice --headless --convert-to pdf out.docx
# (Running .md straight through soffice leaves raw **/#/--- markdown in the PDF —
# that's the "user awam bingung" formatting bug.) fonts-liberation = decent fidelity.
RUN apt-get update && \
    apt-get install -y --no-install-recommends pandoc libreoffice-writer libreoffice-calc libreoffice-impress fonts-liberation && \
    rm -rf /var/lib/apt/lists/*

# ── agent-browser: token-efficient browser automation via accessibility tree ──
RUN set -eu; \
    case "${TARGETARCH:-amd64}" in \
        amd64) ab_arch=linux-x64 ;; \
        arm64) ab_arch=linux-arm64 ;; \
        *) echo "Unsupported TARGETARCH: ${TARGETARCH}" >&2; exit 1 ;; \
    esac; \
    curl -fsSL --retry 3 \
        "https://github.com/vercel-labs/agent-browser/releases/download/v0.27.3/agent-browser-${ab_arch}" \
        -o /usr/local/bin/agent-browser && \
    chmod +x /usr/local/bin/agent-browser

# ── Viko patches — LAST so patch changes don't bust npm/uv/apt cache ──────────
# Changing any file in patches/ only rebuilds from here onwards (~2-3 min)
COPY patches/whatsapp-bridge.js /tmp/viko-wa-bridge.js
COPY patches/indonesian-locale.py /tmp/indonesian-locale.py
COPY patches/patch-ssh-guard.py /tmp/patch-ssh-guard.py
COPY patches/patch-model-router.py /tmp/patch-model-router.py
COPY patches/patch-approval-sql-context.py /tmp/patch-approval-sql-context.py
COPY patches/patch-tool-call-repair.py /tmp/patch-tool-call-repair.py
COPY patches/patch-tool-result-pruning.py /tmp/patch-tool-result-pruning.py
COPY patches/patch-memory-flush-compact.py /tmp/patch-memory-flush-compact.py
COPY patches/patch-session-context-inject.py /tmp/patch-session-context-inject.py
COPY patches/isolation-guard.py /opt/hermes/docker/viko-isolation-guard.py
COPY scripts/init-hermes-config.py /opt/viko/scripts/init-hermes-config.py
RUN if [ -f /opt/hermes/scripts/whatsapp-bridge/bridge.js ]; then \
        cp /tmp/viko-wa-bridge.js /opt/hermes/scripts/whatsapp-bridge/bridge.js; \
    fi
# Hermes moved the bridge lookup path from scripts/ to plugins/scripts/ — symlink both.
RUN mkdir -p /opt/hermes/plugins/scripts && \
    ln -sf /opt/hermes/scripts/whatsapp-bridge /opt/hermes/plugins/scripts/whatsapp-bridge
RUN python3 /tmp/indonesian-locale.py
RUN python3 /tmp/patch-ssh-guard.py
RUN python3 /tmp/patch-model-router.py
RUN python3 /tmp/patch-approval-sql-context.py
RUN python3 /tmp/patch-tool-call-repair.py
RUN python3 /tmp/patch-tool-result-pruning.py
RUN python3 /tmp/patch-memory-flush-compact.py
RUN python3 /tmp/patch-session-context-inject.py

# ── Permissions — after patches so patched files get correct ownership ─────────
RUN mkdir -p /opt/hermes/gateway && \
    chmod -R a+rX /opt/hermes && \
    chown -R hermes:hermes /opt/hermes/.venv /opt/hermes/ui-tui \
        /opt/hermes/gateway /opt/hermes/node_modules \
        /opt/hermes/scripts/whatsapp-bridge

# ── s6 service wiring (mirrors official Dockerfile) ───────────────────────────
RUN mkdir -p /etc/cont-init.d /etc/s6-overlay/s6-rc.d && \
    printf '#!/command/with-contenv sh\nexec /opt/hermes/docker/stage2-hook.sh\n' \
        > /etc/cont-init.d/01-hermes-setup && \
    chmod +x /etc/cont-init.d/01-hermes-setup && \
    cp /opt/hermes/docker/cont-init.d/015-supervise-perms /etc/cont-init.d/ && \
    cp /opt/hermes/docker/cont-init.d/02-reconcile-profiles /etc/cont-init.d/ && \
    chmod +x /etc/cont-init.d/015-supervise-perms \
              /etc/cont-init.d/02-reconcile-profiles && \
    cp -r /opt/hermes/docker/s6-rc.d/. /etc/s6-overlay/s6-rc.d/ && \
    printf '#!/command/with-contenv sh\nexec python3 /opt/hermes/docker/viko-isolation-guard.py\n' \
        > /etc/cont-init.d/03-viko-isolation-guard && \
    chmod +x /etc/cont-init.d/03-viko-isolation-guard && \
    printf '#!/command/with-contenv sh\npython3 /opt/viko/scripts/init-hermes-config.py /opt/data/config.yaml\n' \
        > /etc/cont-init.d/04-viko-hermes-config && \
    chmod +x /etc/cont-init.d/04-viko-hermes-config && \
    printf '#!/command/with-contenv sh\nREPO="${VIKO_PROJECTS_ROOT}/viko-agent"\n[ -f "$REPO/admin/SOUL.md" ] && cp "$REPO/admin/SOUL.md" /opt/data/SOUL.md || true\n' \
        > /etc/cont-init.d/05-viko-soul && \
    chmod +x /etc/cont-init.d/05-viko-soul

# ── Exec shim (privilege-drop for docker exec) ────────────────────────────────
RUN mkdir -p /opt/hermes/bin && \
    cp /opt/hermes/docker/hermes-exec-shim.sh /opt/hermes/bin/hermes && \
    chmod +x /opt/hermes/bin/hermes

# ── viko helper: send latest browser recording as WA video ────────────────────
COPY scripts/viko-send-video.sh /opt/hermes/bin/viko-send-video
RUN chmod +x /opt/hermes/bin/viko-send-video

# ── GitHub CLI (admin onboarding: gh secret set, repo ops) ────────────────────
# Placed AFTER the chown layer so bumping it never re-pulls the large perms layer.
# gh auto-authenticates from the GITHUB_TOKEN env var (admin container only).
RUN set -eu; \
    case "${TARGETARCH:-amd64}" in \
        amd64) gh_arch=amd64 ;; \
        arm64) gh_arch=arm64 ;; \
        *) echo "Unsupported TARGETARCH: ${TARGETARCH}" >&2; exit 1 ;; \
    esac; \
    gh_ver="$(curl -fsSL https://api.github.com/repos/cli/cli/releases/latest | grep -oP '"tag_name": *"v\K[^"]+')"; \
    curl -fsSL --retry 3 \
        "https://github.com/cli/cli/releases/download/v${gh_ver}/gh_${gh_ver}_linux_${gh_arch}.tar.gz" \
        -o /tmp/gh.tar.gz; \
    tar -xzf /tmp/gh.tar.gz -C /tmp; \
    install -m 0755 "/tmp/gh_${gh_ver}_linux_${gh_arch}/bin/gh" /usr/local/bin/gh; \
    rm -rf /tmp/gh.tar.gz "/tmp/gh_${gh_ver}_linux_${gh_arch}"; \
    gh --version

# ── Runtime environment ───────────────────────────────────────────────────────
ENV HERMES_WEB_DIST=/opt/hermes/hermes_cli/web_dist
ENV HERMES_TUI_DIR=/opt/hermes/ui-tui
ENV HERMES_HOME=/opt/data
ENV PATH="/opt/hermes/bin:/opt/hermes/.venv/bin:/opt/data/.local/bin:${PATH}"

RUN mkdir -p /opt/data
VOLUME ["/opt/data"]
EXPOSE 8642 8644

ENTRYPOINT ["/init", "/opt/hermes/docker/main-wrapper.sh"]
CMD []
