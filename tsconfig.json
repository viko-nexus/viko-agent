{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["node"],

    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,

    // Pragmatic strictness for a dynamic, Baileys-heavy JS bridge: catch real
    // type bugs (undefined refs, bad property access, null/undefined misuse)
    // without forcing every glue-code parameter to carry an explicit type.
    // noImplicitAny stays off — the agent's message objects are inherently dynamic.
    "strict": false,
    "strictNullChecks": true,
    "noImplicitAny": false,

    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "patches/whatsapp-bridge.js",
    "patches/allowlist.d.ts",
    "bridge/**/*.js",
    "types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "**/node_modules", "data", "backups"]
}
