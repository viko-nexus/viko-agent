# Data volumes (bind-mounted into Docker — never committed, persists on laptop)
data/

# Backups
backups/

# Claude Code local config — settings are user-specific, skills are tracked
.claude/settings.json

# macOS
.DS_Store
**/.DS_Store

# Logs and temp
logs/
*.log
*.tmp

# Secrets
.env
*.env
*-env-backup.txt

# Project context — contains client info, server details, internal paths
# Each user maintains their own projects/ locally — never committed to git
# Exception: viko-agent (meta-project, safe to share) is tracked explicitly
projects/forecast-crm/
projects/forecast-inn/
projects/luxso/
projects/mankop/
projects/viko-assistant/
# Catch-all: any future project added by Viko stays local
projects/*/

# Python cache
__pycache__/
*.pyc
*.pyo

# Node
node_modules

# Local dev override — bind-mounts source over the image (local-only, never deploy)
docker-compose.override.yml

# Local .env backups created by dev-init.sh (contain secrets)
.env.bak*

# AI planning-session transcripts — tend to capture real ops details (SSH
# aliases, deploy paths, client project names) that shouldn't be public.
# Existing committed files under this path are intentionally left as-is;
# this only stops new ones from being tracked.
docs/superpowers/plans/
