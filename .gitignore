# Data volumes (bind-mounted into Docker — never committed, persists on laptop)
data/

# Backups
backups/

# Claude Code local config — settings are user-specific, skills are tracked
.claude/settings.json

# macOS
.DS_Store
**/.DS_Store

# Logs and temp
logs/
*.log
*.tmp

# Secrets
.env
*.env
*-env-backup.txt

# Project context — contains client info, server details, internal paths
# Each user maintains their own projects/ locally — never committed to git
# Exception: viko-agent (meta-project, safe to share) is tracked explicitly
projects/forecast-crm/
projects/forecast-inn/
projects/luxso/
projects/mankop/
projects/viko-assistant/
# Catch-all: any future project added by Viko stays local
projects/*/

# Python cache
__pycache__/
*.pyc
*.pyo

# Node
node_modules
