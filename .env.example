# Viko Agent — Environment Variables
# Copy this to .env and fill in the values.
# NEVER commit .env to git.

# ── 9router: service config ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NINEROUTER_JWT_SECRET=
NINEROUTER_INITIAL_PASSWORD=
NINEROUTER_API_KEY_SECRET=

# ── 9router: provider API keys ───────────────────────────────────────────────
# NOT passed to containers — enter these in the 9router dashboard:
# http://localhost:20128/dashboard → Providers
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Hermes: 9router client key ───────────────────────────────────────────────
# Get from 9router dashboard after setup: Dashboard → API Keys → Create
OPENAI_API_KEY=

# ── Hermes: user/group IDs ───────────────────────────────────────────────────
# Match your host user so bind-mount files are owned correctly.
# Run: id -u && id -g
HERMES_UID=501
HERMES_GID=20

# ── Hermes: WhatsApp home channel ────────────────────────────────────────────
# The JID that Viko sends startup notifications to and accepts commands from.
# Format: <phone_number>@s.whatsapp.net  (individual) or <id>@g.us  (group)
WHATSAPP_HOME_CHANNEL=

# ── GitHub: HTTPS clone during onboarding ────────────────────────────────────
# Classic PAT with 'repo' scope (or fine-grained limited to onboarded repos).
# add-project.py clones project repos via https://<token>@github.com/... — there
# are NO per-repo deploy keys anymore. One token works for all projects.
# NOT injected into project containers (they can't clone). REQUIRED to onboard.
# Get from: github.com/settings/tokens → Tokens (classic) → repo scope
GITHUB_TOKEN=

# ── Viko SSH public key ───────────────────────────────────────────────────────
# id_viko.pub dari trahku — paste ke authorized_keys VPS user saat onboard project baru
# Get from: cat /home/viko/.viko/ssh/id_viko.pub  (on trahku)
VIKO_SSH_PUB=

# ── Paths ─────────────────────────────────────────────────────────────────────
# Root folder where all your projects live. Used by Viko to:
#   - Set terminal working directory
#   - Know where to scaffold new project code
# Must be inside ~/Projects/ since that's what docker-compose mounts.
VIKO_PROJECTS_ROOT=/home/youruser/Projects

# ── Dashboard bind address ───────────────────────────────────────────────────
# Host/IP the Hermes dashboard (9119) and 9router dashboard (20128) bind to.
# Default 127.0.0.1 (loopback only). Set to this host's Tailscale IP (e.g.
# 100.x.y.z) to reach the dashboards over Tailscale without exposing them on the
# public interface. Use 0.0.0.0 only behind a firewall.
VIKO_BIND_ADDR=127.0.0.1

# ── Option B: project routing ────────────────────────────────────────────────
# Per-project Hermes instances are routed via data/bridge/routing.json
# (not via WHATSAPP_TRUSTED_GROUPS). Routing is managed by spawn-hermes.py.
# No manual changes needed here for project routing.

# ── Project isolation guard (boot-time backstop) ─────────────────────────────
# Each per-project container runs isolation-guard.py before the gateway starts,
# verifying its capability isolation (scoped mount, per-project SSH key, no
# GITHUB_TOKEN, relay token maps only to its own group, etc.).
#   warn    = log + tombstone on failure, keep running (default, safe)
#   enforce = on failure the container goes inert (unhealthy, gateway won't start)
#   off     = skip the guard
VIKO_ISOLATION_GUARD=warn

