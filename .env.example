# ============================================================
# viko-agent — VPS A Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ------------------------------------------------------------
# System Identity
# ------------------------------------------------------------

# Prefix for all Viko containers and networks.
# Container names: {VIKO_NAME}-admin, {VIKO_NAME}-9router, {VIKO_NAME}-{slug}
# Network name: {VIKO_NAME}-internal
# Change this if running multiple Viko instances on the same Docker host.
VIKO_NAME=viko

# WhatsApp number of the system owner.
# ONLY this number can issue commands to Hermes-Admin or any Hermes-Project.
# Format: country code + number, no + or spaces (e.g., 6281234567890)
WHATSAPP_OWNER_NUMBER=

# Owner display name — written into each project's context.md so Viko-Project can
# recognize/greet the owner by name and attribute who may authorize execution.
VIKO_OWNER_NAME=

# WhatsApp group JID that receives container startup notifications (optional).
# Format: XXXXXXXXXX@g.us
WHATSAPP_HOME_CHANNEL=

# ------------------------------------------------------------
# 9router Configuration
# ------------------------------------------------------------

# Internal JWT and admin password for the 9router service itself.
# Generate: openssl rand -hex 32
NINEROUTER_JWT_SECRET=
NINEROUTER_INITIAL_PASSWORD=
NINEROUTER_API_KEY_SECRET=

# Provider API keys — entered in 9router dashboard, NOT passed to containers.
# Dashboard: http://localhost:20128/dashboard → Providers
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# API key for Hermes containers to call 9router (9router client key).
# REQUIRED — Hermes will not be able to reach the LLM gateway without it.
# Get from: 9router dashboard → API Keys → Create
OPENAI_API_KEY=

# 9router endpoint — accessed internally by all Hermes containers.
# Do not change unless 9router moves to a different host.
OPENAI_BASE_URL=http://${VIKO_NAME}-9router:20128/v1

# ------------------------------------------------------------
# GitHub
# ------------------------------------------------------------

# Fine-grained PAT with per-repo scope. Used by:
#   - Hermes-Admin: clone private repos during Phase 1 onboarding
#   - Hermes-Project: github-mcp-server (PR, issues, releases, tagging)
# Required permissions: contents:rw, pull_requests:w, issues:w, metadata:r, actions:r
GITHUB_TOKEN=

# ------------------------------------------------------------
# Postgres Admin (Phase 2 project setup only)
# ------------------------------------------------------------

# Used ONLY during Phase 2 to CREATE per-project roles and databases.
# NOT used for app queries — those use per-project credentials from project.json.
# Source: your deploy VPS infra/.env (the postgres superuser account).
POSTGRES_ADMIN_HOST=
POSTGRES_ADMIN_PORT=5432
POSTGRES_ADMIN_USER=
POSTGRES_ADMIN_PASSWORD=

# ------------------------------------------------------------
# Container / Host Config
# ------------------------------------------------------------

# Host UID/GID — match your deploy user so bind-mount files are owned correctly.
# Run: id -u && id -g
HERMES_UID=1000
HERMES_GID=1000

# Absolute path on the host where project repos are cloned/checked out.
# REQUIRED — bind-mounted into Hermes containers at the same path.
# Each project lives at $VIKO_PROJECTS_ROOT/<slug>/.
# Example (VPS): /home/viko/projects  |  Example (local dev): /Users/you/Projects
VIKO_PROJECTS_ROOT=/home/viko/projects

# Boot-time per-project isolation guard mode (fail-closed backstop).
# enforce → on failure, container goes inert and refuses to start (default).
# warn    → on failure, log only and continue startup.
# off     → skip the check entirely.
VIKO_ISOLATION_GUARD=enforce

# ------------------------------------------------------------
# Notes
# ------------------------------------------------------------

# Per-project DB credentials (role, password, redis index) are stored in:
#   /home/deploy/{slug}/config/project.json
# They are NOT stored here to avoid exposure via `docker inspect`.

# 9router model combos (hermes-chat, hermes-code) are configured by:
#   python3 scripts/init-9router.py
# Model settings are set at 9router runtime, not here.

# Deploy VPS infra container names ({vps_name}-postgres, {vps_name}-redis) are
# auto-detected by Hermes-Project during Phase 2 via SSH + docker ps.
